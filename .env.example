# 复制为 .env 后可按本机环境修改；.env 已被 Git 忽略。
CREATIVEBENCH_ENVIRONMENT=development
CREATIVEBENCH_LOG_LEVEL=INFO
CREATIVEBENCH_DATA_DIR=data
CREATIVEBENCH_TAXONOMY_PATH=data/taxonomy.json
CREATIVEBENCH_EXAMPLES_PATH=data/examples/prompts.jsonl
CREATIVEBENCH_IMPORT_OUTPUT_PATH=data/processed/imported_prompts.jsonl
CREATIVEBENCH_DEDUP_OUTPUT_PATH=data/processed/deduplicated_prompts.jsonl
CREATIVEBENCH_DEDUP_REPORT_PATH=data/processed/duplicate_report.jsonl
CREATIVEBENCH_MIN_PROMPT_LENGTH=5
CREATIVEBENCH_MAX_PROMPT_LENGTH=10000
CREATIVEBENCH_NEAR_DUPLICATE_MAX_DISTANCE=8
CREATIVEBENCH_SEMANTIC_DUPLICATE_THRESHOLD=0.80
CREATIVEBENCH_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
