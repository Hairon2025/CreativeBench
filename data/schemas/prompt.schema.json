{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creativebench.local/schemas/prompt.schema.json",
  "title": "CreativeBench Prompt Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "prompt_text",
    "language",
    "scope",
    "source",
    "labels",
    "annotation",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^cbp-[0-9]{4,}$"
    },
    "prompt_text": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "scope": {
      "enum": ["creative_writing", "risk_test", "out_of_scope"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "enum": ["synthetic", "public_web", "internal", "manual"]
        },
        "reference": {
          "type": ["string", "null"]
        }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["genres", "intents", "roles", "risks"],
      "properties": {
        "genres": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["suspense", "romance", "sci_fi", "history", "fantasy", "wuxia", "realism", "horror"]
          }
        },
        "intents": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["story_continuation", "character_design", "style_imitation", "plot_generation", "text_rewriting"]
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["no_explicit_role", "model_role", "user_role", "multi_role", "character_profile"]
          }
        },
        "risks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["normal", "prompt_injection", "instruction_override", "roleplay_jailbreak", "sensitive_inducement", "privacy_request"]
          }
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source", "confidence", "rationale", "annotator"],
      "properties": {
        "status": {
          "enum": ["pending", "approved", "rejected"]
        },
        "source": {
          "enum": ["human", "model", "imported"]
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "annotator": {
          "type": ["string", "null"]
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
